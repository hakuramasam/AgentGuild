{
  "name": "Agent Guild",
  "version": "1.0.0",
  "description": "Production-ready AI agent on Base Mainnet with ERC-402 payment system",
  "chainId": 8453,
  "rpcUrl": "https://mainnet.base.org",
  "payment": {
    "x402Receiver": "0x21c2b22b7dD5634Af6fc0bc5489965bb906a9959",
    "usdcAddress": "0x833589fcd6edb6e08f4c7c32d4f71b54bda02913",
