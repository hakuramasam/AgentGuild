  },
  "costs": {
    "free": "0",
    "lightweight": "10000",
    "heavyweight": "100000",
    "ultraHeavy": "500000"
  },
  "tools": {
    "total": 37,
    "free": 1,
    "lightweight": 24,
    "heavyweight": 10,
    "ultraHeavy": 2
  },
  "features": {
    "inputValidation": true,
    "rateLimiting": true,
    "timeoutHandling": true,
    "retryLogic": true,
    "errorHandling": true,
    "logging": true,
    "metrics": false
  },
  "environment": {
    "THIRDWEB_CLIENT_ID": "${THIRDWEB_CLIENT_ID}",
    "THIRDWEB_SECRET_KEY": "${THIRDWEB_SECRET_KEY}",
    "REDIS_URL": "redis://localhost:6379",
