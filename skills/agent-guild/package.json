{
  "name": "agent-guild",
  "version": "1.0.0",
  "description": "Production-ready AI agent on Base Mainnet with ERC-402 payment system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node-dev src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "thirdweb": "^5.0.0",
    "@thirdweb-dev/sdk": "^5.0.0",
    "ethers": "^6.0.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "winston": "^3.8.0",
    "rate-limiter-flexible": "^5.0.0",
    "redis": "^4.6.0",
    "prom-client": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "agent",
    "guild",
    "thirdweb",
    "base",
    "erc-402",
    "payment",
    "mcp",
    "ai"
  ],
  "author": "Hakurama Sam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hakuramasam/AgentGuild.git"
  },
  "bugs": {
    "url": "https://github.com/hakuramasam/AgentGuild/issues"
  },
  "homepage": "https://github.com/hakuramasam/AgentGuild#readme"
}
